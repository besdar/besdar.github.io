{
    "name": "besdar.github.io",
    "author": "besdar",
    "description": "Personal CV",
    "homepage": "https://besdar.github.io",
    "scripts": {
        "dev": "npm run build:all && vite preview --host 0.0.0.0",
        "build:site": "node build/build-site.mjs",
        "build:browser": "vite build",
        "build:all": "npm run build:site && npm run build:browser",
        "deploy": "gh-pages -d dist",
        "check:js": "eslint --cache .",
        "check:styles": "stylelint \"./public/css/**/*.css\" \"./src/**/*.css\"",
        "check:types": "tsc --noEmit",
        "check:all": "npm run check:js && npm run check:styles && npm run check:types",
        "project-checking": "concurrently \"npm:check-*\"",
        "eslint:fix": "eslint --fix ./src && prettier --write src/",
        "styles:fix": "stylelint --fix \"./public/css/**/*.css\"",
        "lint:fix": "npm run eslint:fix && npm run styles:fix"
    },
    "browserslist": {
        "production": [
            ">1%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@mdx-js/rollup": "^3.1.1",
        "@types/mdx": "^2.0.13",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^9.2.1",
        "eslint": "^10.4.0",
        "gh-pages": "^6.3.0",
        "prettier": "^3.8.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "stylelint": "^17.12.0",
        "stylelint-config-standard": "^40.0.0",
        "svgo": "^4.0.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^8.0.13"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
